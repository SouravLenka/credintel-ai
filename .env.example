# ================================
# CredIntel AI — Environment Variables
# ================================
# Copy this file to .env and fill in your values.

# ── App ──────────────────────────────────────────────────
APP_NAME=CredIntel AI
DEBUG=false
ENVIRONMENT=development

# ── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/credintel

# ── AI / LLM ─────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-70b-8192
OPENAI_API_KEY=your_openai_key_here_optional
SERPAPI_API_KEY=your_serpapi_api_key_here_optional

# ── ChromaDB ─────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma

# ── File Storage ─────────────────────────────────────────
UPLOAD_DIR=./data/uploads
MAX_FILE_SIZE_MB=50

# ── Firebase ─────────────────────────────────────────────
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# ── CORS ─────────────────────────────────────────────────
# Comma-separated list
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# ── Frontend (Next.js) ───────────────────────────────────
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_firebase_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
